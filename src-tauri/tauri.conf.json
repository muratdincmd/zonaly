{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zonaly",
  "version": "0.7.0",
  "identifier": "com.zonaly.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zonaly",
        "width": 900,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "center": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Zonaly",
        "width": 280,
        "height": 280,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "center": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": true,
        "url": "splashscreen.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "headerImage": "icons/installer-banner.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "macOS": {
      "dmg": {
        "background": "icons/dmg-background.png",
        "appPosition": { "x": 180, "y": 220 },
        "applicationFolderPosition": { "x": 480, "y": 220 },
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  }
}
